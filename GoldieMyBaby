<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>100 Things I Love About You ❤️</title>

<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #ffe6eb, #fff5f7);
        margin: 0;
        padding: 20px;
        color: #333;
    }

    .container {
        max-width: 900px;
        margin: auto;
        background: white;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    h1 {
        text-align: center;
        color: #ff4d79;
    }

    .letter {
        font-size: 1.1rem;
        line-height: 1.8;
        margin-bottom: 40px;
    }

    .heart {
        text-align: center;
        font-size: 2rem;
        animation: pulse 1.5s infinite;
    }

    @keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.15); }
        100% { transform: scale(1); }
    }

    ol {
        line-height: 2;
    }

    li {
        margin-bottom: 8px;
        padding: 8px;
        border-left: 4px solid #ff8fab;
        background: #fff8fa;
        border-radius: 5px;
    }

    footer {
        text-align: center;
        margin-top: 40px;
        color: #888;
    }
</style>
</head>
